# ---- MCP server ----------------------------------------------------------
# Bearer token claude.ai sends in the Authorization header. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CASHTAG_AUTH_TOKEN=

# SQLite for v1; swap for postgresql+psycopg://... with no code changes.
CASHTAG_DATABASE_URL=sqlite:///cashtag.db

PORT=8000

# ---- Classification (Anthropic) -----------------------------------------
ANTHROPIC_API_KEY=

# ---- Reddit (free, non-commercial tier) ---------------------------------
# Register a "script" app at https://www.reddit.com/prefs/apps
# The free non-commercial tier requires a separate approval form; allow 2-4 weeks.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit REQUIRES a descriptive UA with contact info or it will 429/403 you.
REDDIT_USER_AGENT=python:cashtag:0.1.0 (by /u/YOUR_USERNAME)

# ---- X / Twitter (pay-per-use, ~$0.005/read, no free tier) --------------
# Leave X_ENABLED=false until you have deliberately funded the account.
X_ENABLED=false
X_BEARER_TOKEN=
# Hard ceiling. The worker refuses to spend past this and logs a warning.
X_MONTHLY_BUDGET_USD=25.00

# ---- Bright Data (Instagram + TikTok) -----------------------------------
BRIGHTDATA_ENABLED=false
BRIGHTDATA_API_KEY=

# ---- StockTwits (free, no auth) -----------------------------------------
# Cross-check source: posts are self-tagged bullish/bearish by their authors.
STOCKTWITS_ENABLED=true
